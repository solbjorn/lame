@ENABLE_UNIT_TESTS_TRUE@TESTS = $(check_PROGRAMS)
@ENABLE_UNIT_TESTS_TRUE@test_sanity_SOURCES = test_sanity.c
@ENABLE_UNIT_TESTS_TRUE@test_sanity_CPPFLAGS = $(CMOCKA_CFLAGS)
@ENABLE_UNIT_TESTS_TRUE@test_sanity_LDADD = $(CMOCKA_LIBS)

# The AIFF header parser lives in frontend/get_audio.c and is static, so the
# test compiles it in directly (hence the frontend/libmp3lame/include search
# paths). fread is wrapped to trap the underflow spin the guard prevents.
@ENABLE_UNIT_TESTS_TRUE@test_get_audio_aiff_SOURCES = test_get_audio_aiff.c test_stubs.c
@ENABLE_UNIT_TESTS_TRUE@test_get_audio_aiff_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/frontend \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/libmp3lame \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_get_audio_aiff_LDFLAGS = -Wl,--wrap=fread
@ENABLE_UNIT_TESTS_TRUE@test_get_audio_aiff_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la


# The positional-filename length guard set_path_arg() lives in
# frontend/parse.c and is static, so the test compiles that file in directly;
# parse_test_stubs.c supplies the console/file helpers it references and
# libmp3lame provides the lame_* API.
@ENABLE_UNIT_TESTS_TRUE@test_parse_pathlen_SOURCES = test_parse_pathlen.c parse_test_stubs.c
@ENABLE_UNIT_TESTS_TRUE@test_parse_pathlen_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/frontend \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/libmp3lame \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_parse_pathlen_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	$(LTLIBICONV) -lm


# merge_argv() is likewise static in frontend/parse.c; same include/link setup.
@ENABLE_UNIT_TESTS_TRUE@test_merge_argv_SOURCES = test_merge_argv.c parse_test_stubs.c
@ENABLE_UNIT_TESTS_TRUE@test_merge_argv_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/frontend \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/libmp3lame \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_merge_argv_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	$(LTLIBICONV) -lm


# The id3tag_* API is public, so this test links libmp3lame and calls it
# directly - no frontend translation unit compiled in.
@ENABLE_UNIT_TESTS_TRUE@test_id3tag_SOURCES = test_id3tag.c
@ENABLE_UNIT_TESTS_TRUE@test_id3tag_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_id3tag_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	-lm


# The frontend ID3 dispatch (id3_tag/set_id3v2tag_*) is static in parse.c, so
# this test compiles parse.c in directly; same include/link setup as the other
# parse.c tests.
@ENABLE_UNIT_TESTS_TRUE@test_parse_id3_SOURCES = test_parse_id3.c parse_test_stubs.c
@ENABLE_UNIT_TESTS_TRUE@test_parse_id3_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/frontend \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/libmp3lame \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_parse_id3_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	$(LTLIBICONV) -lm


# The encoding entry points are public, so this test links libmp3lame and calls
# them directly - no frontend translation unit compiled in.
@ENABLE_UNIT_TESTS_TRUE@test_encode_nonfinite_SOURCES = test_encode_nonfinite.c
@ENABLE_UNIT_TESTS_TRUE@test_encode_nonfinite_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_encode_nonfinite_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	-lm


# The interleaved entry points are public, so this test links libmp3lame and
# calls them directly - no frontend translation unit compiled in.
@ENABLE_UNIT_TESTS_TRUE@test_encode_mono_interleaved_SOURCES = test_encode_mono_interleaved.c
@ENABLE_UNIT_TESTS_TRUE@test_encode_mono_interleaved_CPPFLAGS = $(CMOCKA_CFLAGS) \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_srcdir)/include \
@ENABLE_UNIT_TESTS_TRUE@	-I$(top_builddir)

@ENABLE_UNIT_TESTS_TRUE@test_encode_mono_interleaved_LDADD = $(CMOCKA_LIBS) \
@ENABLE_UNIT_TESTS_TRUE@	$(top_builddir)/libmp3lame/libmp3lame.la \
@ENABLE_UNIT_TESTS_TRUE@	-lm

all: all-am

.SUFFIXES:
.SUFFIXES: .c .lo .log .o .obj .test .test$(EXEEXT) .trs
$(srcdir)/Makefile.in: @MAINTAINER_MODE_TRUE@ $(srcdir)/Makefile.am $(top_srcdir)/Makefile.am.global $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      ( cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh ) \
	        && { if test -f $@; then exit 0; else break; fi; }; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign test/unit/Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --foreign test/unit/Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $(subdir)/$@ $(am__maybe_remake_depfiles);; \
	esac;
$(top_srcdir)/Makefile.am.global $(am__empty):

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh

$(top_srcdir)/configure: @MAINTAINER_MODE_TRUE@ $(am__configure_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(ACLOCAL_M4): @MAINTAINER_MODE_TRUE@ $(am__aclocal_m4_deps)
	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):

clean-checkPROGRAMS:
	$(am__rm_f) $(check_PROGRAMS)
	test -z "$(EXEEXT)" || $(am__rm_f) $(check_PROGRAMS:$(EXEEXT)=)

test_encode_mono_interleaved$(EXEEXT): $(test_encode_mono_interleaved_OBJECTS) $(test_encode_mono_interleaved_DEPENDENCIES) $(EXTRA_test_encode_mono_interleaved_DEPENDENCIES) 
	@rm -f test_encode_mono_interleaved$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_encode_mono_interleaved_OBJECTS) $(test_encode_mono_interleaved_LDADD) $(LIBS)

test_encode_nonfinite$(EXEEXT): $(test_encode_nonfinite_OBJECTS) $(test_encode_nonfinite_DEPENDENCIES) $(EXTRA_test_encode_nonfinite_DEPENDENCIES) 
	@rm -f test_encode_nonfinite$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_encode_nonfinite_OBJECTS) $(test_encode_nonfinite_LDADD) $(LIBS)

test_get_audio_aiff$(EXEEXT): $(test_get_audio_aiff_OBJECTS) $(test_get_audio_aiff_DEPENDENCIES) $(EXTRA_test_get_audio_aiff_DEPENDENCIES) 
	@rm -f test_get_audio_aiff$(EXEEXT)
	$(AM_V_CCLD)$(test_get_audio_aiff_LINK) $(test_get_audio_aiff_OBJECTS) $(test_get_audio_aiff_LDADD) $(LIBS)

test_id3tag$(EXEEXT): $(test_id3tag_OBJECTS) $(test_id3tag_DEPENDENCIES) $(EXTRA_test_id3tag_DEPENDENCIES) 
	@rm -f test_id3tag$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_id3tag_OBJECTS) $(test_id3tag_LDADD) $(LIBS)

test_merge_argv$(EXEEXT): $(test_merge_argv_OBJECTS) $(test_merge_argv_DEPENDENCIES) $(EXTRA_test_merge_argv_DEPENDENCIES) 
	@rm -f test_merge_argv$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_merge_argv_OBJECTS) $(test_merge_argv_LDADD) $(LIBS)

test_parse_id3$(EXEEXT): $(test_parse_id3_OBJECTS) $(test_parse_id3_DEPENDENCIES) $(EXTRA_test_parse_id3_DEPENDENCIES) 
	@rm -f test_parse_id3$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_parse_id3_OBJECTS) $(test_parse_id3_LDADD) $(LIBS)

test_parse_pathlen$(EXEEXT): $(test_parse_pathlen_OBJECTS) $(test_parse_pathlen_DEPENDENCIES) $(EXTRA_test_parse_pathlen_DEPENDENCIES) 
	@rm -f test_parse_pathlen$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_parse_pathlen_OBJECTS) $(test_parse_pathlen_LDADD) $(LIBS)

test_sanity$(EXEEXT): $(test_sanity_OBJECTS) $(test_sanity_DEPENDENCIES) $(EXTRA_test_sanity_DEPENDENCIES) 
	@rm -f test_sanity$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(test_sanity_OBJECTS) $(test_sanity_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

